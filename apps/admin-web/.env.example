# PlayConnect Admin Web — Environment Configuration
# Copy this file to .env.local and fill in actual values.
# NEVER commit .env files with real secrets.

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
TZ=Asia/Kolkata

# API (server-only — points to NestJS API)
API_BASE_URL=http://localhost:3001

# Cookie encryption (server-only)
# COOKIE_SECRET: min 32 chars, used as key material for AES-256-GCM session encryption
# COOKIE_SALT: min 16 chars hex string, used as scrypt salt for key derivation
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=
COOKIE_SALT=
