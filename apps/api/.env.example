# PlayConnect API — Environment Configuration
# Copy this file to .env and fill in actual values.
# NEVER commit .env files with real secrets.

# Application
APP_ENV=development
NODE_ENV=development
PORT=3001
TZ=Asia/Kolkata

# Database
MONGODB_URI=mongodb://localhost:27017/playconnect_dev

# Logging
LOG_LEVEL=debug

# JWT Authentication
JWT_ACCESS_SECRET=CHANGE_ME_use_a_random_string_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_use_a_random_string_min_32_chars
JWT_ACCESS_TTL=900          # 15 minutes in seconds
JWT_REFRESH_TTL=2592000     # 30 days in seconds

# Password Hashing
BCRYPT_COST=12              # bcrypt cost factor (4-31)

# Secret Provider (development: local, staging/production: SECRET_PROVIDER)
SECRET_PROVIDER=local

# SMTP / Email
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@playconnect.app
EMAIL_DRY_RUN=true              # true = log only, no real emails
FEE_REMINDER_ENABLED=false      # kill-switch for fee reminder cron

# Reliability
EXTERNAL_CALL_TIMEOUT_MS=10000     # Timeout for external HTTP calls (ms)
EXTERNAL_CALL_RETRIES=1            # Max retries for idempotent external calls (0-3)
SMTP_TIMEOUT_MS=10000              # SMTP send timeout (ms)
SHUTDOWN_GRACE_MS=20000            # Grace period for graceful shutdown (ms)

# Cashfree Payment Gateway
CASHFREE_CLIENT_ID=             # Cashfree PG app ID
CASHFREE_CLIENT_SECRET=         # Cashfree PG secret key (NEVER expose to client)
CASHFREE_WEBHOOK_SECRET=        # Webhook secret for signature verification
CASHFREE_API_VERSION=2025-01-01
CASHFREE_BASE_URL=https://sandbox.cashfree.com/pg  # Use https://api.cashfree.com/pg for production

# Swagger / OpenAPI
SWAGGER_ENABLED=true            # set false to disable docs entirely
SWAGGER_TOKEN=                  # optional: require x-swagger-token header for docs access
