{
  "name": "@playconnect/api",
  "version": "0.0.0",
  "private": true,
  "description": "PlayConnect API — NestJS backend (Clean Architecture + DDD)",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs --testPathPattern '\\.spec\\.ts$'",
    "test:e2e": "jest --config jest.config.cjs --testPathPattern 'e2e-spec'",
    "validate:architecture": "node scripts/validate-architecture.mjs",
    "contract:check": "node scripts/contract-check.mjs",
    "swagger:generate": "ts-node -r tsconfig-paths/register src/swagger-generate.ts",
    "test:cashfree": "jest --config jest.config.cjs --testPathPattern 'cashfree.*\\.spec\\.ts$'",
    "test:payments": "jest --config jest.config.cjs --testPathPattern '(subscription-payment|fee-payment|cashfree).*\\.spec\\.ts$'"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@types/pdfkit": "^0.17.5",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.3.1",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.5",
    "nestjs-pino": "^4.2.0",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.17.2",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.1",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@playconnect/eslint-config": "*",
    "@playconnect/tsconfig": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
